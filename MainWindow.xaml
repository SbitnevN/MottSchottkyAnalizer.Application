<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MottSchottkyAnalizer.Application"
        xmlns:menu="clr-namespace:MottSchottkyAnalizer.Controls.CustomMenu;assembly=MottSchottkyAnalizer.Controls"
        xmlns:oxy="http://oxyplot.org/wpf"
        x:Class="MottSchottkyAnalizer.Application.MainWindow"
        mc:Ignorable="d"
        Title="MainWindow" Height="720" Width="1280" Background="{StaticResource White}">
    <Grid>
        <menu:MenuView DataContext="{Binding MenuViewModel}"/>
        <TabControl Background="{StaticResource White}" Margin="0 25 0 0">
            <TabItem Header="Координаты Боде">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Side-->

                    <!-- Right Side-->
                    <oxy:PlotView Grid.Column="1" Background="{StaticResource White}" Margin="20" Model="{Binding PlotModel}"/>
                </Grid>
            </TabItem>

            <TabItem Header="Координаты Мотта-Шоттки">
                <oxy:PlotView Grid.Column="1" Background="{StaticResource White}" Margin="10,10,10,50"/>
            </TabItem>
        </TabControl>


    </Grid>
</Window>
