<Window
    x:Class="MottSchottkyAnalizer.Application.Main.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:drawer="clr-namespace:MottSchottkyAnalizer.Controls.Controls.Drawer;assembly=MottSchottkyAnalizer.Controls"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:MottSchottkyAnalizer.Application"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:oxy="http://oxyplot.org/wpf"
    xmlns:text="clr-namespace:MottSchottkyAnalizer.Controls.Controls.LabeledTextBox;assembly=MottSchottkyAnalizer.Controls"
    Title="MainWindow"
    Width="1280"
    Height="720"
    MinWidth="1280"
    MinHeight="720"
    Background="{StaticResource White}"
    WindowState="Normal"
    mc:Ignorable="d">


    <Grid>
        <DockPanel>

            <Border
                Margin="20,10"
                Padding="20,5"
                VerticalAlignment="Top"
                DockPanel.Dock="Top"
                Style="{StaticResource CardStyle}">

                <DockPanel LastChildFill="False">

                    <Button
                        Width="47"
                        Height="47"
                        HorizontalContentAlignment="Center"
                        Command="{Binding MenuViewModel.OpenDrawer}"
                        Content="&#xf142;"
                        DockPanel.Dock="Left"
                        FontFamily="{StaticResource Icons}"
                        FontSize="{StaticResource HugeFontSize}"
                        Style="{StaticResource GhostButtonStyle}" />

                    <TextBlock
                        Padding="10,0"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource TitleFont}"
                        FontSize="{StaticResource BigFontSize}"
                        Text="MSAnylizer" />

                    <Button
                        Width="47"
                        Height="47"
                        HorizontalContentAlignment="Center"
                        Command="{Binding HistoryViewModel.OpenDrawer}"
                        Content="&#xf1da;"
                        DockPanel.Dock="Right"
                        FontFamily="{StaticResource Icons}"
                        FontSize="{StaticResource HugeFontSize}"
                        Style="{StaticResource GhostButtonStyle}" />


                </DockPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--#region LeftSide-->
                <ScrollViewer Grid.Column="0">
                    <StackPanel>
                        <StackPanel>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock
                                        FontFamily="{StaticResource TitleFont}"
                                        FontSize="{StaticResource BigFontSize}"
                                        Text="∮Потенциалы:" />

                                    <Separator Margin="0,5" />

                                    <DockPanel>
                                        <StackPanel>
                                            <text:LabeledTextBoxView
                                                Width="200"
                                                HorizontalAlignment="Left"
                                                FontSize="{StaticResource NormalFontSize}"
                                                Label="Начальный потенциал, В."
                                                Text="{Binding PotentialViewModel.Start, StringFormat=N2, Mode=TwoWay}" />

                                            <text:LabeledTextBoxView
                                                Width="200"
                                                HorizontalAlignment="Left"
                                                FontSize="{StaticResource NormalFontSize}"
                                                Label="Конечный потенциал, В."
                                                Text="{Binding PotentialViewModel.End, StringFormat=N2, Mode=TwoWay}" />

                                            <text:LabeledTextBoxView
                                                Width="200"
                                                HorizontalAlignment="Left"
                                                FontSize="{StaticResource NormalFontSize}"
                                                Label="Шаг потенциала, В."
                                                Text="{Binding PotentialViewModel.Step, StringFormat=N2, Mode=TwoWay}" />

                                            <Button
                                                Margin="0,5"
                                                Command="{Binding PotentialViewModel.Recalc}"
                                                Content="Рассчет шага"
                                                Style="{StaticResource PrimaryButtonStyle}" />

                                            <Button
                                                Margin="0,5"
                                                Command="{Binding PotentialViewModel.Reverse}"
                                                Content="Инвертировать"
                                                Style="{StaticResource PrimaryButtonStyle}" />

                                            <Button
                                                Margin="0,5"
                                                Command="{Binding PotentialViewModel.Reverse}"
                                                Content="Заблокировать"
                                                Style="{StaticResource PrimaryButtonStyle}" />
                                        </StackPanel>

                                        <DataGrid
                                            Width="300"
                                            Height="300"
                                            Margin="30,0"
                                            AutoGenerateColumns="False">

                                            <DataGrid.Columns>
                                                <DataGridTextColumn
                                                    Width="auto"
                                                    Header="Шаг"
                                                    IsReadOnly="True" />
                                                <DataGridTextColumn Width="*" Header="Потенциал" />
                                            </DataGrid.Columns>

                                        </DataGrid>

                                    </DockPanel>

                                </StackPanel>
                            </Border>

                        </StackPanel>

                        <StackPanel Margin="0,10">
                            <TextBlock
                                FontFamily="{StaticResource TitleFont}"
                                FontSize="{StaticResource BigFontSize}"
                                Text="⩗Частота: ~" />

                            <Separator Margin="0,5" />

                            <StackPanel>
                                <Button
                                    Width="180"
                                    Margin="0,10"
                                    Content="Выбрать частоту"
                                    FontFamily="{StaticResource TextFont}"
                                    FontSize="{StaticResource SmallFontSize}" />
                                <Button
                                    Width="180"
                                    Margin="0,10"
                                    Content="Выбрать частоту"
                                    FontFamily="{StaticResource TextFont}"
                                    FontSize="{StaticResource SmallFontSize}" />
                                <Button
                                    Width="180"
                                    Margin="0,10"
                                    Content="Выбрать частоту"
                                    FontFamily="{StaticResource TextFont}"
                                    FontSize="{StaticResource SmallFontSize}" />
                                <Button
                                    Width="180"
                                    Margin="0,10"
                                    Content="Выбрать частоту"
                                    FontFamily="{StaticResource TextFont}"
                                    FontSize="{StaticResource SmallFontSize}" />
                                <Button
                                    Width="180"
                                    Margin="0,10"
                                    Content="Выбрать частоту"
                                    FontFamily="{StaticResource TextFont}"
                                    FontSize="{StaticResource SmallFontSize}" />
                                <Button
                                    Width="180"
                                    Margin="0,10"
                                    Content="Выбрать частоту"
                                    FontFamily="{StaticResource TextFont}"
                                    FontSize="{StaticResource SmallFontSize}" />
                                <Button
                                    Width="180"
                                    Margin="0,10"
                                    Content="Выбрать частоту"
                                    FontFamily="{StaticResource TextFont}"
                                    FontSize="{StaticResource SmallFontSize}" />
                                <Button
                                    Width="180"
                                    Margin="0,10"
                                    Content="Выбрать частоту"
                                    FontFamily="{StaticResource TextFont}"
                                    FontSize="{StaticResource SmallFontSize}" />
                                <Button
                                    Width="180"
                                    Margin="0,10"
                                    Content="Выбрать частоту"
                                    FontFamily="{StaticResource TextFont}"
                                    FontSize="{StaticResource SmallFontSize}" />

                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
                <!--#endregion-->

                <!--#region RightSide-->

                <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                    <TabControl Style="{StaticResource TabControlStyle}">

                        <TabItem Header="Боде" Style="{StaticResource TabItemStyle}">
                            <oxy:PlotView
                                Background="{StaticResource PanelBrush}"
                                FontFamily="{StaticResource TextFont}"
                                FontSize="{StaticResource HugeFontSize}"
                                Model="{Binding BodePlotModel}" />
                        </TabItem>

                        <TabItem Header="Мота-Шотки" Style="{StaticResource TabItemStyle}">
                            <oxy:PlotView
                                Background="{StaticResource PanelBrush}"
                                FontFamily="{StaticResource TextFont}"
                                FontSize="{StaticResource HugeFontSize}"
                                Model="{Binding SchottkyPlotModel}" />
                        </TabItem>

                    </TabControl>
                </Border>
                <!--#endregion-->
            </Grid>
        </DockPanel>

        <!--#region Drawer-->

        <drawer:DrawerOverlayView DataContext="{Binding OverlayViewModel}" />

        <drawer:DrawerView
            Width="300"
            Padding="5,15"
            HorizontalAlignment="Left"
            d:Margin="-300,0"
            DataContext="{Binding MenuViewModel}">
            <StackPanel>
                <TextBlock
                    FontFamily="{StaticResource TitleFont}"
                    FontSize="{StaticResource HugeFontSize}"
                    Text="Меню" />
                <Separator />

            </StackPanel>
        </drawer:DrawerView>

        <drawer:DrawerView
            Width="300"
            Padding="5,15"
            HorizontalAlignment="Right"
            d:Margin="-300,0"
            DataContext="{Binding HistoryViewModel}">

            <StackPanel>
                <TextBlock
                    FontFamily="{StaticResource TitleFont}"
                    FontSize="{StaticResource HugeFontSize}"
                    Text="История" />

                <Separator />
            </StackPanel>
        </drawer:DrawerView>

        <!--#endregion-->
    </Grid>
</Window>
